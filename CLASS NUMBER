#include <iostream>
using namespace std;

class Number
{
private:
    int value;

public:
    Number(int v = 0)
    {
        value = v;
    }

    Number operator-()
    {
        return Number(-value);
    }

    void display()
    {
        cout << "Value = " << value << endl;
    }
};

int main()
{
    Number n1(10);
    Number n2;

    n2 = -n1;

    cout << "Original Number: ";
    n1.display();

    cout << "Negated Number: ";
    n2.display();

    return 0;
}
